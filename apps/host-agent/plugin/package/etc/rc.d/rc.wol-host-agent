#!/bin/bash

PLUGIN="wol-host-agent"
DAEMON="/usr/local/sbin/wol-host-agent"
CFG="/boot/config/plugins/${PLUGIN}/${PLUGIN}.cfg"
ENV_FILE="/boot/config/plugins/${PLUGIN}/${PLUGIN}.env"
PID_FILE="/var/run/${PLUGIN}.pid"
LOG_FILE="/var/log/${PLUGIN}.log"

read_cfg_value() {
	local key="$1"
	local fallback="$2"

	if [[ -f "$CFG" ]]; then
		local value
		value="$(grep -E "^${key}=" "$CFG" | tail -n 1 | cut -d= -f2- | sed -e 's/^"//' -e 's/"$//')"
		if [[ -n "$value" ]]; then
			echo "$value"
			return
		fi
	fi

	echo "$fallback"
}

is_running() {
	[[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" >/dev/null 2>&1
}

start() {
	if is_running; then
		echo "${PLUGIN} is already running"
		return 0
	fi

	if [[ "$(read_cfg_value ENABLED yes)" != "yes" ]]; then
		echo "${PLUGIN} is disabled"
		return 0
	fi

	if [[ ! -x "$DAEMON" ]]; then
		echo "${DAEMON} is missing or not executable"
		return 1
	fi

	if [[ ! -f "$ENV_FILE" ]]; then
		/usr/local/emhttp/plugins/${PLUGIN}/scripts/apply.sh
	fi

	set -a
	# shellcheck disable=SC1090
	source "$ENV_FILE"
	set +a

	if [[ -z "$HOST_AGENT_TOKEN" ]]; then
		echo "HOST_AGENT_TOKEN is required. Configure it in Settings > WOL Host Agent."
		return 1
	fi

	nohup "$DAEMON" >>"$LOG_FILE" 2>&1 &
	echo "$!" > "$PID_FILE"
	echo "${PLUGIN} started"
}

stop() {
	if ! is_running; then
		rm -f "$PID_FILE"
		echo "${PLUGIN} is not running"
		return 0
	fi

	kill "$(cat "$PID_FILE")" >/dev/null 2>&1 || true
	sleep 1
	if is_running; then
		kill -9 "$(cat "$PID_FILE")" >/dev/null 2>&1 || true
	fi
	rm -f "$PID_FILE"
	echo "${PLUGIN} stopped"
}

restart() {
	stop
	start
}

status() {
	if is_running; then
		echo "Running"
	else
		echo "Stopped"
	fi
}

case "$1" in
	start)
		start
		;;
	stop)
		stop
		;;
	restart)
		restart
		;;
	status)
		status
		;;
	*)
		echo "Usage: $0 {start|stop|restart|status}"
		exit 1
		;;
esac
